NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anonima

# Solo servidor (Settings → API → service_role). Nunca expongas esto al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_secret

# Slug del negocio (debe coincidir con tenant_slug en bookido_services / bookido_bookings)
NEXT_PUBLIC_BOOKIDO_TENANT_SLUG=yorbana

# Horario del calendario de reservas (hora local del navegador del visitante)
BOOKIDO_OPEN_HOUR=10
BOOKIDO_CLOSE_HOUR=20
BOOKIDO_SLOT_MINUTES=30

# Opcional: solo dígitos con prefijo país, sin + ni espacios (ej. España: 34612345678)
NEXT_PUBLIC_WHATSAPP_E164=34612345678

# Email transaccional (Resend — https://resend.com)
RESEND_API_KEY=
